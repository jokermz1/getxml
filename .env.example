# Configurações do Sistema
APP_NAME=GetXML SEFAZ
APP_ENV=development
APP_DEBUG=true

# Configurações SEFAZ
SEFAZ_UF=SP
SEFAZ_AMBIENTE=1
SEFAZ_CERTIFICADO=
SEFAZ_SENHA_CERTIFICADO=

# CNPJ para captura das notas
CNPJ_CNPJ=
CNPJ_IE=

# Período de captura (opcional)
DATA_INICIO=
DATA_FIM=

# Configurações de armazenamento
STORAGE_PATH=storage/xmls
